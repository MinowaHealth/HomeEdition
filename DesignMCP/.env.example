# DesignMCP environment.
#
# USERAPP_API_KEY is the long-lived hbk_* token for the rodrigo@borgia.family
# demo identity. Issue with:
#   ~/UserApp/admin.py issue-api-key rodrigo@borgia.family designmcp
# and paste the token here. It will not be shown again.

USERAPP_BASE_URL=http://hb-local-webapp:80
USERAPP_API_KEY=

# Server
MCP_PORT=33282
MCP_HOST=0.0.0.0
UVICORN_LOG_LEVEL=info

# Compose — join the canonical appliance stack's network (see
# HowToDeploy/docker-compose.local.yml). Bring that stack up first.
BIND_ADDR=127.0.0.1
DOCKER_NETWORK=minowa
