# local.env — Unified local Docker Compose environment
# Used with: docker compose -f docker-compose.local.yml --env-file local.env up -d
#
# These are LOCAL DEV credentials only. Not secret.

# ── Bind address + timezone (local vs VM/appliance) ──
# BIND_ADDR controls which host interface the web UI (:80) and UserMCP (:13282)
# bind to.
#   127.0.0.1 (default) — local install: loopback only, nothing on the LAN.
#   0.0.0.0             — VM / appliance install: reachable by other LAN
#                         devices (phones, MCP clients, etc.).
# This is the ONLY difference between a local and a VM install.
BIND_ADDR=127.0.0.1
TZ=America/Los_Angeles

# ── Postgres bind address (independent of BIND_ADDR) ──
# PG_BIND_ADDR controls the DB port (:5432) ONLY, and defaults to loopback
# even on a LAN appliance. A direct DB connection bypasses all app-level
# user_id scoping (there is no RLS), so exposing Postgres is a deliberate
# opt-in, separate from exposing the app. Leave at 127.0.0.1 unless you are
# intentionally pointing an external tool / Postgres MCP at the box.
#   127.0.0.1 (default) — DB reachable only from the box itself.
#   0.0.0.0             — DB reachable from the LAN. See PostgresAccess.md.
PG_BIND_ADDR=127.0.0.1

# ── PostgreSQL superuser ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Password2026

# ── Application role (app-level user_id scoping; no RLS) ──
APP_DB_USER=healthv10_app
APP_DB_PASSWORD=Password2026

# ── Database ──
DB_HOST=hb-local-postgres
DB_PORT=5432
DB_NAME=healthv10

# ── Webapp (UserApp) ──
DEFAULT_TENANT_ID=1
FLASK_ENV=production
# Flask three-tier logging vocabulary: BASIC | STANDARD | DEBUG
FLASK_LOG_LEVEL=STANDARD
# Python stdlib / uvicorn vocabulary: critical | error | warning | info | debug | trace
UVICORN_LOG_LEVEL=info

SECRET_KEY=local-dev-secret-key-not-for-production

# ── UserMCP (Python, port 13282) ──
API_BASE_URL=http://hb-local-webapp:80
MCP_PORT=13282

