# API Configuration
# Local development: http://localhost (direct connection)
# Docker (reaching host machine): http://host.docker.internal (Docker for Mac/Windows)
# Docker (reaching another container): http://webapp (if on same network)
API_BASE_URL=http://localhost

# Server Configuration
MCP_PORT=13282
MCP_HOST=0.0.0.0
UVICORN_LOG_LEVEL=info

# Message tracing — dump raw MCP JSON-RPC messages to stdout
# Set to 1 and run `docker compose up` (no -d) to see traffic
MCP_TRACE=
