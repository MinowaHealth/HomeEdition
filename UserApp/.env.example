# UserApp Environment Configuration
# Copy this to .env and update values

# ============================================================================
# DATABASE CREDENTIALS
# ============================================================================

# Postgres superuser (container init / maintenance only — the webapp
# connects as the app role below)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Password2026

# App credentials (non-superuser role used by all services)
# This role is created by Infrastructure/init/docker-init-home/role/app-role-setup.sql
APP_DB_USER=healthv10_app
APP_DB_PASSWORD=Password2026

# ============================================================================
# OPTIONAL INTEGRATIONS
# ============================================================================

# Environment label shown in logs
DEPLOY_ENV=home
# App label shown in logs
APP_LABEL=UserApp

# HealthKit sync token (for background sync).
# These two variables are a paired contract — set BOTH or set NEITHER.
# Setting HEALTHKIT_SYNC_TOKEN with an empty HEALTHKIT_SYNC_USERNAME makes
# the runtime token-auth path fall through to the lowest-ID active user
# (F3 finding from 2ndOpinion.md). The validator at
# webapp/validate_env.py refuses to boot in that combination — see
# 4thDegree.md Track 6. To enable: set HEALTHKIT_SYNC_USERNAME to the
# email of the user the token acts on behalf of.
HEALTHKIT_SYNC_TOKEN=
HEALTHKIT_SYNC_USERNAME=

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change_this_to_random_value

# ============================================================================
# CORS — WEB SPA ORIGINS
# ============================================================================
#
# Comma-separated list of origins permitted to call /api/* via fetch from a
# browser. Required for the patient web SPA to round-trip when it's served
# from a different host/port than the API. Mobile clients ignore CORS — this
# is browser-only.
#
# Dev default (used when this var is unset) covers Mac Docker compose + RN dev
# server only. If you serve the SPA from another LAN host, override with that
# origin explicitly.
# See web-spa-backend-contract.md §1 + §0.5 for the auth-model + CORS rationale.
#
# Examples:
#   Local dev (default):  http://localhost:80,http://127.0.0.1:80,http://10.0.2.2:80
#   Other LAN host:       http://192.168.1.50:80
#
# Never use '*' — CORS spec forbids wildcard + credentials together; browsers
# will reject the response.
CORS_ORIGINS=
